<!-- Фрагмент главной страницы. Загружается в <main> через fetch -->

<section class="add-section">
  <form id="task-form" class="task-form">
    <input
      id="task-input"
      class="task-input"
      type="text"
      placeholder="НОВАЯ ЗАДАЧА..."
      autocomplete="off"
      required
    />
    <button class="btn-add" type="submit">ADD</button>
  </form>
</section>

<section class="tasks-section">
  <div class="tasks-header">
    <span class="tasks-title">СПИСОК ЗАДАЧ</span>
    <span id="tasks-count" class="tasks-count">0</span>
  </div>
  <ul id="tasks-list" class="tasks-list"></ul>
  <div id="empty-state" class="empty-state">
    <span>// задачи отсутствуют</span>
  </div>
</section>
