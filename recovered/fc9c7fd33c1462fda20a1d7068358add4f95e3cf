<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#0a0a0a">
  <link rel="icon" href="/icons/icon-32.png" type="image/png">
  <link rel="apple-touch-icon" href="/icons/icon-192.png">

  <title>TASKS // PC PARTS</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <div class="app">

    <!--
      КАРКАС (App Shell) — этот HTML кэшируется навсегда.
      Шапка и навигация всегда доступны, даже без интернета.
      Содержимое <main> подгружается отдельно через fetch.
    -->

    <header class="header">
      <div class="header-brand">
        <span class="header-icon">⚙</span>
        <span class="header-title">TASK_MANAGER</span>
      </div>
      <div id="status" class="status status--online">ONLINE</div>
    </header>

    <nav class="nav">
      <button id="btn-home"  class="nav-btn nav-btn--active">ЗАДАЧИ</button>
      <button id="btn-about" class="nav-btn">О ПРИЛОЖЕНИИ</button>
    </nav>

    <!-- Сюда динамически подгружается content/home.html или content/about.html -->
    <main id="app-content" class="main"></main>

    <footer class="footer">
      <span id="sw-status">SERVICE WORKER: ЗАГРУЗКА...</span>
    </footer>

  </div>

  <script src="app.js"></script>
</body>
</html>